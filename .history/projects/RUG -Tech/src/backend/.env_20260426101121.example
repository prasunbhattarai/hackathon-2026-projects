# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=FundusAI Backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string (Supabase, Neon, or local Postgres)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fundusai

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get these from: cloudinary.com -> Dashboard -> API Keys
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# ── Upload constraints (defaults shown; override only if needed) ─────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_MIN_DIMENSION_PX=224

# ── PDF ───────────────────────────────────────────────────────────────────────
PDF_DOWNLOAD_EXPIRY_SECONDS=3600

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array format expected by pydantic-settings
CORS_ORIGINS=["http://localhost:3000"]
